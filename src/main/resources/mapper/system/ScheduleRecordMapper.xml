<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.youlai.boot.system.mapper.ScheduleRecordMapper">

    <!-- 操作记录分页列表查询 -->
    <select id="getScheduleRecordPage" resultType="com.youlai.boot.system.model.vo.DashboardStatsVO">
        SELECT
        id,
        sn_code AS snCode,
        operate_type AS operateType,
        before_value AS beforeValue,
        after_value AS afterValue,
        operate_user AS operateUser,
        operate_user_name AS operateUserName,
        create_time AS createTime
        FROM
        fqc_schedule_record
        <where>
            <!-- SN号精确查询 -->
            <if test="queryParams.snCode != null and queryParams.snCode.trim() neq ''">
                AND sn_code = #{queryParams.snCode}
            </if>
            <!-- 操作类型精确查询 -->
            <if test="queryParams.operateType != null">
                AND operate_type = #{queryParams.operateType}
            </if>
            <!-- 操作人ID精确查询 -->
            <if test="queryParams.operateUser != null">
                AND operate_user = #{queryParams.operateUser}
            </if>
            <!-- 操作人姓名模糊查询 -->
            <if test="queryParams.operateUserName != null and queryParams.operateUserName.trim() neq ''">
                AND operate_user_name LIKE CONCAT('%', #{queryParams.operateUserName}, '%')
            </if>
            <!-- 操作时间范围查询 -->
            <if test="queryParams.createTime != null and queryParams.createTime.size() > 0">
                <if test="queryParams.createTime[0] != null and queryParams.createTime[0] != ''">
                    <bind name="startDate" value="queryParams.createTime[0].length() == 10 ? queryParams.createTime[0] + ' 00:00:00' : queryParams.createTime[0]"/>
                    AND create_time &gt;= #{startDate}
                </if>
                <if test="queryParams.createTime[1] != null and queryParams.createTime[1] != ''">
                    <bind name="endDate" value="queryParams.createTime[1].length() == 10 ? queryParams.createTime[1] + ' 23:59:59' : queryParams.createTime[1]"/>
                    AND create_time &lt;= #{endDate}
                </if>
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

</mapper>
