<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.youlai.boot.system.mapper.AlgorithmMapper">

    <!-- 算法分页列表 -->
    <select id="getAlgorithmPage" resultType="com.youlai.boot.system.model.bo.AlgorithmBO">
        SELECT
            id,
            estimated_finish_time,
            adjust_count,
            warehouse_warning_flag,
            shell_robot_utilization,
            create_time,
            update_time
        FROM
            abb_algorithm_result
        <where>
            is_deleted = 0
            <if test='queryParams.estimatedFinishTime!=null and queryParams.estimatedFinishTime.trim() neq ""'>
                AND estimated_finish_time LIKE CONCAT('%',#{queryParams.estimatedFinishTime},'%')
            </if>
            <if test='queryParams.adjustCount!=null'>
                AND adjust_count = #{queryParams.adjustCount}
            </if>
            <if test='queryParams.warehouseWarningFlag!=null and queryParams.warehouseWarningFlag.trim() neq ""'>
                AND warehouse_warning_flag = #{queryParams.warehouseWarningFlag}
            </if>
            <if test='queryParams.shellRobotUtilization!=null'>
                AND shell_robot_utilization = #{queryParams.shellRobotUtilization}
            </if>
        </where>
        <choose>
            <!-- 如果排序参数都传入 -->
            <when test="queryParams.field != null and queryParams.field != '' and queryParams.direction != null">
                ORDER BY ${queryParams.field} ${queryParams.direction}
            </when>
            <!-- 默认排序 -->
            <otherwise>
                ORDER BY id DESC
            </otherwise>
        </choose>
    </select>

    <!-- 算法表单信息映射 -->
    <resultMap id="AlgorithmFormMap" type="com.youlai.boot.system.model.form.AlgorithmForm">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="estimatedFinishTime" column="estimated_finish_time" jdbcType="VARCHAR"/>
        <result property="adjustCount" column="adjust_count" jdbcType="INTEGER"/>
        <result property="warehouseWarningFlag" column="warehouse_warning_flag" jdbcType="VARCHAR"/>
        <result property="shellRobotUtilization" column="shell_robot_utilization" jdbcType="DECIMAL"/>
    </resultMap>

    <!-- 根据算法ID获取算法表单数据 -->
    <select id="getAlgorithmFormData" resultMap="AlgorithmFormMap">
        SELECT
            id,
            estimated_finish_time,
            adjust_count,
            warehouse_warning_flag,
            shell_robot_utilization
        FROM
            abb_algorithm_result
        WHERE
            id = #{algorithmId} AND is_deleted = 0
    </select>

</mapper>
